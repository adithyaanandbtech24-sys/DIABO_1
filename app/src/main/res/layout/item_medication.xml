<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:background="@color/medicalPurpleLight"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iv_med_icon"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/heart_icon"
            app:tint="@color/vibrantPurple" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tv_med_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Metformin"
                android:textColor="@color/medicalPurpleDeep"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_med_dosage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="500mg • Once Daily"
                android:textColor="@color/gray"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_med_source"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detected from document"
                android:textColor="@color/gray"
                android:textSize="10sp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:background="#1A808080"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
